# Next.js: .env.local overrides .env. Do not leave the Supabase vars below empty in .env.local
# or they will override real values in .env and break auth/middleware.
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
POSTGRES_DATABASE="postgres"
POSTGRES_HOST=

# Trustless Work (Stellar escrow)
NEXT_PUBLIC_TRUSTLESS_WORK_API_KEY=
NEXT_PUBLIC_TRUSTLESS_NETWORK=testnet
NEXT_PUBLIC_MERCATO_PLATFORM_ADDRESS=
NEXT_PUBLIC_TRUSTLESSLINE_ADDRESS=
NEXT_PUBLIC_DEFINDEX_API_KEY=
NEXT_PUBLIC_DEFINDEX_VAULT_ADDRESS=
# NEXT_PUBLIC_DEFINDEX_API_URL=https://api.defindex.io

# DeFindex (yield vault)
NEXT_PUBLIC_DEFINDEX_API_KEY=
NEXT_PUBLIC_DEFINDEX_API_URL=
# Vault contract for balance sync (must match the network in NEXT_PUBLIC_TRUSTLESS_NETWORK)
NEXT_PUBLIC_DEFINDEX_VAULT_ADDRESS=

# Pollar (embedded wallet onboarding)
# In dashboard.pollar.xyz → Domains, add each origin you use (e.g. http://localhost:3000 — exact scheme host port).
# Missing origin causes API errors like ORIGIN_NOT_ALLOWED on Google/GitHub login.
# Server-side verification forwards the browser Origin; if your proxy strips it, set the same URL here:
# POLLAR_ALLOWED_ORIGIN=http://localhost:3000
# For API routes (/api/auth/pollar-sync), duplicate your publishable key here so the server always has it
# (some Next setups resolve NEXT_PUBLIC_* inconsistently on the server).
POLLAR_PUBLISHABLE_KEY=
NEXT_PUBLIC_POLLAR_PUBLISHABLE_KEY=
POLLAR_SECRET_KEY=
POLLAR_WEBHOOK_SECRET=
NEXT_PUBLIC_POLLAR_NETWORK=testnet

# Ramp (fiat on/off) — configure one or more providers; users choose which to use in the app.
# Set env vars for each provider you want to offer. If none are set, ramp is disabled.

# Etherfuse (Mexico, SPEI, CETES)
# ETHERFUSE_API_KEY=
# ETHERFUSE_BASE_URL=https://api.sand.etherfuse.com

# AlfredPay (Mexico, SPEI, USDC)
# ALFREDPAY_API_KEY=
# ALFREDPAY_API_SECRET=
# ALFREDPAY_BASE_URL=https://penny-api-restricted-dev.alfredpay.io/api/v1/third-party-service/penny

# BlindPay (global)
# BLINDPAY_API_KEY=
# BLINDPAY_INSTANCE_ID=
# BLINDPAY_BASE_URL=https://api.blindpay.com
